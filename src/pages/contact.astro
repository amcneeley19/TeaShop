---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SHOP_NAME, SHOP_ADDRESS, SHOP_PHONE, SHOP_EMAIL, SHOP_HOURS } from '../data/config';

export const prerender = true;
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact — ${SHOP_NAME}`} description={`Visit ${SHOP_NAME} at ${SHOP_ADDRESS}. Find our hours, location, and send us a message.`} />
	</head>
	<body>
		<Header />
		<section class="page-hero">
			<span class="label">Get in Touch</span>
			<h1>Contact</h1>
			<p class="subtitle">We'd love to hear from you</p>
		</section>
		<main>
			<div class="contact-layout">
				<div class="form-section">
					<h2>Send a Message</h2>
					<form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
						<input type="hidden" name="form-name" value="contact" />
						<p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
						<div class="field">
							<label for="name">Your Name</label>
							<input type="text" id="name" name="name" required placeholder="Jane Smith" />
						</div>
						<div class="field">
							<label for="email">Email Address</label>
							<input type="email" id="email" name="email" required placeholder="jane@example.com" />
						</div>
						<div class="field">
							<label for="subject">Subject</label>
							<input type="text" id="subject" name="subject" placeholder="Tea recommendation, art inquiry..." />
						</div>
						<div class="field">
							<label for="message">Message</label>
							<textarea id="message" name="message" rows="5" required placeholder="Tell us what's on your mind..."></textarea>
						</div>
						<button type="submit" class="btn">Send Message</button>
					</form>
				</div>

				<div class="info-section">
					<div class="info-card">
						<h2>Shop Info</h2>
						<div class="info-block">
							<h3>Address</h3>
							<address>{SHOP_ADDRESS}</address>
						</div>
						<div class="info-block">
							<h3>Phone</h3>
							<p><a href={`tel:${SHOP_PHONE.replace(/[^0-9]/g, '')}`}>{SHOP_PHONE}</a></p>
						</div>
						<div class="info-block">
							<h3>Email</h3>
							<p><a href={`mailto:${SHOP_EMAIL}`}>{SHOP_EMAIL}</a></p>
						</div>
						<div class="info-block">
							<h3>Hours</h3>
							<ul class="hours-list">
								{SHOP_HOURS.map((h: { days: string; hours: string }) => (
									<li>
										<span class="day">{h.days}</span>
										<span class="time">{h.hours}</span>
									</li>
								))}
							</ul>
						</div>
					</div>

					<div class="map-placeholder">
						<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
						<p>Map embed goes here</p>
						<p class="hint">Replace with Google Maps iframe for {SHOP_ADDRESS}</p>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-hero {
		background: var(--forest-mist);
		padding: var(--space-3xl) var(--space-lg) var(--space-xl);
		text-align: center;
	}
	.page-hero .label { margin-bottom: var(--space-xs); display: block; }
	.page-hero h1 { margin-bottom: var(--space-xs); }
	.subtitle {
		font-family: 'Cormorant Garamond', serif;
		color: var(--text-muted);
		font-style: italic;
		font-size: var(--text-lg);
		margin: 0;
	}

	.contact-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-3xl);
		align-items: start;
	}
	.form-section h2,
	.info-card h2 {
		font-size: var(--text-2xl);
		margin-bottom: var(--space-lg);
	}
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}
	.hidden { display: none; }
	.field {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}
	.field label {
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
	}
	.field input,
	.field textarea {
		padding: 0.7em 0.9em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-md);
		background: #fff;
		color: var(--text);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-base);
		transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
		width: 100%;
		box-sizing: border-box;
	}
	.field input:focus,
	.field textarea:focus {
		outline: none;
		border-color: var(--forest);
		box-shadow: 0 0 0 3px rgba(61, 90, 62, 0.1);
	}
	.field textarea { resize: vertical; }
	.btn {
		display: inline-block;
		padding: 0.8em 2em;
		background: var(--copper);
		color: #fff;
		border: 2px solid var(--copper);
		border-radius: var(--radius-sm);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
		align-self: flex-start;
	}
	.btn:hover {
		background: var(--copper-dark);
		border-color: var(--copper-dark);
		transform: translateY(-1px);
	}

	.info-card {
		background: var(--forest-mist);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		margin-bottom: var(--space-lg);
	}
	.info-block { margin-bottom: var(--space-lg); }
	.info-block:last-child { margin-bottom: 0; }
	.info-block h3 {
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--forest);
		margin-bottom: var(--space-xs);
	}
	.info-block p,
	.info-block address {
		color: var(--text-muted);
		font-size: var(--text-base);
		margin: 0;
		font-style: normal;
	}
	.info-block a {
		color: var(--copper);
		text-decoration: none;
	}
	.info-block a:hover { color: var(--copper-dark); }

	.hours-list { list-style: none; padding: 0; margin: 0; }
	.hours-list li {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-sm);
		padding: var(--space-xs) 0;
	}
	.day { color: var(--text-muted); }
	.time { color: var(--text); font-weight: 600; }

	.map-placeholder {
		background: var(--parchment-dark);
		border: 2px dashed var(--border-strong);
		border-radius: var(--radius-lg);
		height: 200px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: var(--space-md);
		color: var(--text-muted);
		opacity: 0.6;
	}
	.map-placeholder p { margin: var(--space-xs) 0; font-size: var(--text-sm); }
	.hint { font-size: var(--text-xs) !important; font-style: italic; }

	@media (max-width: 768px) {
		.contact-layout { grid-template-columns: 1fr; }
	}
</style>
