---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SHOP_NAME } from '../data/config';
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SHOP_NAME}`} description="Discover the story behind Art Expressions | Infinite Tea — a tea house and art shop in historic Waynesville, Ohio." />
	</head>
	<body>
		<Header />
		<section class="page-hero">
			<span class="label">Our Story</span>
			<h1>About</h1>
			<p class="subtitle">Tea, art, and community in the heart of Waynesville</p>
		</section>
		<main>
			<div class="prose-content">
				<section>
					<h2>More Than a Tea Shop</h2>
					<p>
						Art Expressions | Infinite Tea is a place where the warmth of a good cup of tea meets
						the joy of discovering something beautiful. Nestled on High Street in historic
						Waynesville — known as the Antiques Capital of the Midwest — our shop is part tea house,
						part art gallery, and part treasure hunt.
					</p>
					<p>
						We carry over 225 varieties of loose-leaf tea from around the world, alongside a
						curated collection of art, handmade goods, books, soaps, and gifts you won't find
						anywhere else. Whether you're here for a quiet afternoon in our tea room or searching
						for the perfect present, there's always something to discover.
					</p>
				</section>

				<section>
					<h2>What We Believe</h2>
					<div class="values-grid">
						<div class="value-card">
							<span class="value-number">01</span>
							<h3>Every cup tells a story</h3>
							<p>
								Tea connects cultures, traditions, and people. We love sharing the stories behind
								what you're drinking — where it's from, how it's made, and why it tastes the way it does.
							</p>
						</div>
						<div class="value-card">
							<span class="value-number">02</span>
							<h3>Art belongs everywhere</h3>
							<p>
								From the paintings on our walls to the handcrafted mugs you sip from, we believe in
								surrounding yourself with things made with care and intention.
							</p>
						</div>
						<div class="value-card">
							<span class="value-number">03</span>
							<h3>Community is everything</h3>
							<p>
								We're a gathering place for neighbours, friends, and visitors. Everyone is welcome,
								and a warm cup of tea is always waiting.
							</p>
						</div>
					</div>
				</section>

				<section class="cta-section">
					<h2>Come Say Hello</h2>
					<p>
						We're open Monday through Saturday and always happy to chat — about tea, art, life in
						Waynesville, or whatever's on your mind. Stop in and let us brew something for you.
					</p>
					<a href="/contact" class="btn">Find Us</a>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-hero {
		background: var(--forest-mist);
		padding: var(--space-3xl) var(--space-lg) var(--space-xl);
		text-align: center;
	}
	.page-hero .label { margin-bottom: var(--space-xs); display: block; }
	.page-hero h1 { margin-bottom: var(--space-xs); }
	.subtitle {
		font-family: 'Cormorant Garamond', serif;
		color: var(--text-muted);
		font-style: italic;
		font-size: var(--text-lg);
		margin: 0;
	}
	main { max-width: 820px; }

	.prose-content section { margin-bottom: var(--space-3xl); }
	.prose-content h2 { font-size: var(--text-3xl); margin-bottom: var(--space-md); }
	.prose-content p { color: var(--text-muted); line-height: 1.85; }

	.values-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: var(--space-lg);
		margin-top: var(--space-lg);
	}

	.value-card {
		padding: var(--space-xl);
		border: 1px solid var(--border-strong);
		border-radius: var(--radius-lg);
		transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease), border-color var(--duration) var(--ease);
	}
	.value-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
		border-color: var(--copper-light);
	}
	.value-number {
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-2xl);
		font-weight: 300;
		color: var(--dusty-rose);
		display: block;
		margin-bottom: var(--space-xs);
	}
	.value-card h3 { font-size: var(--text-lg); font-weight: 500; margin-bottom: var(--space-sm); }
	.value-card p { font-size: var(--text-sm); margin: 0; }

	.cta-section { text-align: center; }

	.btn {
		display: inline-block;
		padding: 0.8em 2em;
		background: var(--copper);
		color: #fff;
		border: 2px solid var(--copper);
		border-radius: var(--radius-sm);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		font-weight: 600;
		text-decoration: none;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: all var(--duration) var(--ease);
	}
	.btn:hover {
		background: var(--copper-dark);
		border-color: var(--copper-dark);
		color: #fff;
		transform: translateY(-1px);
	}
</style>
