---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TeaList from '../components/TeaList.astro';
import { SHOP_NAME } from '../data/config';
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tea List — ${SHOP_NAME}`} description="Browse our full collection of loose leaf teas..." />
	</head>
	<body>
		<Header />
		<section class="page-hero">
			<span class="label">Our Collection</span>
			<h1>Tea List</h1>
			<p class="subtitle">Browse our full collection of loose leaf teas</p>
		</section>
		<main>
			<TeaList />
		</main>
		<Footer />
	</body>
</html>
<style>
	.page-hero { background: var(--forest-mist); padding: var(--space-3xl) var(--space-lg) var(--space-xl); text-align: center; }
	.page-hero .label { margin-bottom: var(--space-xs); display: block; }
	.page-hero h1 { margin-bottom: var(--space-xs); }
	.subtitle { font-family: 'Cormorant Garamond', serif; color: var(--text-muted); font-style: italic; font-size: var(--text-lg); margin: 0; }
	main { max-width: 1200px; padding: var(--space-2xl) var(--space-lg) var(--space-3xl); }
</style>
