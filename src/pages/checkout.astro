---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SHOP_NAME } from '../data/config';

export const prerender = true;
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Checkout — ${SHOP_NAME}`} description="Complete your order securely." />
	</head>
	<body>
		<Header />
		<section class="page-hero">
			<span class="label">Almost There</span>
			<h1>Checkout</h1>
			<p class="subtitle">Review your order and complete your purchase</p>
		</section>
		<main>
			<div class="checkout-wrapper">

				<!-- Empty cart guard -->
				<div id="empty-cart" class="empty-cart">
					<p>Your cart is empty.</p>
					<a href="/tea-list" class="btn-outline">Browse Teas</a>
				</div>

				<!-- Order summary -->
				<div id="order-summary" class="order-summary hidden">
					<h2>Order Summary</h2>
					<div id="order-items" class="order-items"></div>
					<div class="order-totals">
						<div class="total-row subtotal-row">
							<span>Subtotal</span>
							<span id="order-subtotal">$0.00</span>
						</div>
						<p class="tax-note">Tax calculated at checkout.</p>
					</div>
				</div>

				<!-- Customer info form -->
				<form
					id="checkout-form"
					class="checkout-form hidden"
					data-app-id=""
					data-location-id=""
					novalidate
				>
					<h2>Your Information</h2>
					<div class="field">
						<label for="customer-name">Full Name <span class="required">*</span></label>
						<input
							type="text"
							id="customer-name"
							name="name"
							required
							placeholder="Jane Smith"
							autocomplete="name"
						/>
					</div>
					<div class="field">
						<label for="customer-email">Email Address <span class="required">*</span></label>
						<input
							type="email"
							id="customer-email"
							name="email"
							required
							placeholder="jane@example.com"
							autocomplete="email"
						/>
					</div>
					<div class="field">
						<label for="customer-phone">Phone <span class="optional">(optional)</span></label>
						<input
							type="tel"
							id="customer-phone"
							name="phone"
							placeholder="(513) 555-0100"
							autocomplete="tel"
						/>
					</div>

					<h2>Payment</h2>
					<div class="field">
						<label>Card Details <span class="required">*</span></label>
						<div id="card-container" class="card-container"></div>
					</div>

					<button type="submit" id="place-order-btn" class="btn btn-full" disabled>
						<span id="btn-label">Place Order</span>
						<span id="btn-loading" class="hidden">Processing…</span>
					</button>
				</form>

				<!-- Status messages -->
				<div id="error-message" class="status-msg status-error hidden" role="alert"></div>
				<div id="success-message" class="status-msg status-success hidden" role="status">
					<h3>Order placed!</h3>
					<p>Thank you for your order. You'll receive a confirmation email shortly.</p>
					<a href="/tea-list" class="btn-outline">Continue Shopping</a>
				</div>

			</div>
		</main>
		<Footer />
	</body>
</html>

<script>
	import { cart } from '../lib/cart-browser';

	// ── Helpers ──────────────────────────────────────────────────────────────

	function fmt(cents: number): string {
		return (cents / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
	}

	function fmtDollars(dollars: number): string {
		return dollars.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
	}

	// ── DOM refs ─────────────────────────────────────────────────────────────

	const emptCartEl = document.getElementById('empty-cart')!;
	const orderSummaryEl = document.getElementById('order-summary')!;
	const checkoutFormEl = document.getElementById('checkout-form') as HTMLFormElement;
	const orderItemsEl = document.getElementById('order-items')!;
	const orderSubtotalEl = document.getElementById('order-subtotal')!;
	const placeOrderBtn = document.getElementById('place-order-btn') as HTMLButtonElement;
	const btnLabel = document.getElementById('btn-label')!;
	const btnLoading = document.getElementById('btn-loading')!;
	const errorEl = document.getElementById('error-message')!;
	const successEl = document.getElementById('success-message')!;

	// ── Cart check ───────────────────────────────────────────────────────────

	const items = cart.getCart();

	if (items.length === 0) {
		emptCartEl.classList.remove('hidden');
	} else {
		emptCartEl.classList.add('hidden');
		orderSummaryEl.classList.remove('hidden');
		checkoutFormEl.classList.remove('hidden');
		renderOrderSummary();
		loadSquare();
	}

	function renderOrderSummary() {
		orderItemsEl.innerHTML = '';

		items.forEach((item) => {
			const row = document.createElement('div');
			row.className = 'order-item';

			let description = '';
			let lineTotal = 0;

			if (item.type === 'tea') {
				description = `${item.name} — ${item.ounces} oz`;
				lineTotal = item.ounces * item.pricePerOz;
			} else if (item.type === 'drink') {
				description = `${item.name} (${item.size}) × ${item.qty}`;
				lineTotal = item.qty * item.price;
			} else if (item.type === 'product') {
				description = `${item.name} × ${item.qty}`;
				lineTotal = item.qty * item.price;
			}

			row.innerHTML = `
				<span class="item-desc">${description}</span>
				<span class="item-price">${fmtDollars(lineTotal)}</span>
			`;
			orderItemsEl.appendChild(row);
		});

		orderSubtotalEl.textContent = fmtDollars(cart.getSubtotal());
	}

	// ── Square SDK ───────────────────────────────────────────────────────────

	let squareCard: { tokenize(): Promise<{ status: string; token?: string; errors?: { message: string }[] }> } | null = null;

	function loadSquare() {
		const script = document.createElement('script');
		script.src = 'https://sandbox.web.squarecdn.com/v1/square.js';
		script.onload = initializeSquare;
		script.onerror = () => showError('Failed to load payment SDK. Please refresh and try again.');
		document.head.appendChild(script);
	}

	async function initializeSquare() {
		const form = document.getElementById('checkout-form') as HTMLFormElement | null;
		const appId = form?.dataset.appId || (import.meta.env.PUBLIC_SQUARE_APPLICATION_ID as string | undefined) || '';
		const locationId = form?.dataset.locationId || (import.meta.env.PUBLIC_SQUARE_LOCATION_ID as string | undefined) || '';

		if (!appId || !locationId) {
			showError('Payment configuration is missing. Please contact support.');
			return;
		}

		try {
			const payments = (window as Window & { Square?: { payments(appId: string, locationId: string): Promise<{ card(): Promise<{ attach(selector: string): Promise<void>; tokenize(): Promise<{ status: string; token?: string; errors?: { message: string }[] }> }> }> } }).Square?.payments(appId, locationId);
			if (!payments) {
				showError('Payment SDK failed to initialise. Please refresh and try again.');
				return;
			}
			const card = await payments.card();
			await card.attach('#card-container');
			squareCard = card;

			// Enable submit once card is attached and form is valid
			updateSubmitState();

			// Re-validate on input changes
			checkoutFormEl.addEventListener('input', updateSubmitState);
		} catch (err) {
			showError('Could not initialise payment form. Please refresh and try again.');
			console.error(err);
		}
	}

	function updateSubmitState() {
		const name = (document.getElementById('customer-name') as HTMLInputElement).value.trim();
		const email = (document.getElementById('customer-email') as HTMLInputElement).value.trim();
		const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
		placeOrderBtn.disabled = !(name && emailValid && squareCard);
	}

	// ── Form submit ──────────────────────────────────────────────────────────

	checkoutFormEl.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!squareCard) return;

		const name = (document.getElementById('customer-name') as HTMLInputElement).value.trim();
		const email = (document.getElementById('customer-email') as HTMLInputElement).value.trim();
		const phone = (document.getElementById('customer-phone') as HTMLInputElement).value.trim();

		if (!name || !email) {
			showError('Please fill in all required fields.');
			return;
		}

		setLoading(true);
		hideError();

		try {
			const result = await squareCard.tokenize();

			if (result.status !== 'OK' || !result.token) {
				const msg = result.errors?.map((err) => err.message).join(' ') || 'Card tokenization failed.';
				showError(msg);
				setLoading(false);
				return;
			}

			const response = await fetch('/api/checkout', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					items: cart.getCart(),
					customer: { name, email, phone },
					token: result.token,
				}),
			});

			if (!response.ok) {
				const data = await response.json().catch(() => ({})) as { error?: string };
				showError(data.error || `Order failed (${response.status}). Please try again.`);
				setLoading(false);
				return;
			}

			// Success
			cart.clearCart();
			checkoutFormEl.classList.add('hidden');
			orderSummaryEl.classList.add('hidden');
			successEl.classList.remove('hidden');
		} catch (err) {
			console.error(err);
			showError('An unexpected error occurred. Please try again.');
			setLoading(false);
		}
	});

	// ── UI helpers ───────────────────────────────────────────────────────────

	function setLoading(loading: boolean) {
		placeOrderBtn.disabled = loading;
		btnLabel.classList.toggle('hidden', loading);
		btnLoading.classList.toggle('hidden', !loading);
	}

	function showError(msg: string) {
		errorEl.textContent = msg;
		errorEl.classList.remove('hidden');
	}

	function hideError() {
		errorEl.classList.add('hidden');
		errorEl.textContent = '';
	}
</script>

<style>
	/* ── Hero ── */
	.page-hero {
		background: var(--forest-mist);
		padding: var(--space-3xl) var(--space-lg) var(--space-xl);
		text-align: center;
	}
	.page-hero .label { margin-bottom: var(--space-xs); display: block; }
	.page-hero h1 { margin-bottom: var(--space-xs); }
	.subtitle {
		font-family: 'Cormorant Garamond', serif;
		color: var(--text-muted);
		font-style: italic;
		font-size: var(--text-lg);
		margin: 0;
	}

	/* ── Layout ── */
	main {
		padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
	}
	.checkout-wrapper {
		max-width: 640px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
	}

	/* ── Empty cart ── */
	.empty-cart {
		text-align: center;
		padding: var(--space-3xl) var(--space-lg);
		background: var(--forest-mist);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
	}
	.empty-cart p {
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-xl);
		color: var(--text-muted);
		font-style: italic;
		margin-bottom: var(--space-lg);
	}

	/* ── Order summary ── */
	.order-summary {
		background: var(--forest-mist);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
	}
	.order-summary h2 {
		font-size: var(--text-2xl);
		margin-bottom: var(--space-lg);
	}
	.order-items {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		margin-bottom: var(--space-lg);
		padding-bottom: var(--space-lg);
		border-bottom: 1px solid var(--border-strong);
	}
	.order-item {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: var(--space-md);
		font-size: var(--text-sm);
	}
	.item-desc { color: var(--text-muted); flex: 1; }
	.item-price { color: var(--text); font-weight: 600; white-space: nowrap; }
	.order-totals { display: flex; flex-direction: column; gap: var(--space-xs); }
	.total-row {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-base);
	}
	.subtotal-row { font-weight: 600; }
	.tax-note {
		font-size: var(--text-xs);
		color: var(--text-muted);
		font-style: italic;
		margin: var(--space-xs) 0 0;
	}

	/* ── Checkout form ── */
	.checkout-form {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}
	.checkout-form h2 {
		font-size: var(--text-2xl);
		margin-bottom: 0;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}
	.field label {
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
	}
	.required { color: var(--copper); }
	.optional {
		font-weight: 400;
		text-transform: none;
		letter-spacing: 0;
		font-style: italic;
	}
	.field input {
		padding: 0.7em 0.9em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-md);
		background: #fff;
		color: var(--text);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-base);
		transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
		width: 100%;
		box-sizing: border-box;
	}
	.field input:focus {
		outline: none;
		border-color: var(--forest);
		box-shadow: 0 0 0 3px rgba(61, 90, 62, 0.1);
	}

	/* ── Square card container ── */
	.card-container {
		min-height: 54px;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-md);
		background: #fff;
		padding: 0.4em 0.9em;
		transition: border-color var(--duration) var(--ease);
	}
	.card-container:focus-within {
		border-color: var(--forest);
		box-shadow: 0 0 0 3px rgba(61, 90, 62, 0.1);
	}

	/* ── Buttons ── */
	.btn {
		display: inline-block;
		padding: 0.85em 2em;
		background: var(--copper);
		color: #fff;
		border: 2px solid var(--copper);
		border-radius: var(--radius-sm);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
	}
	.btn:hover:not(:disabled) {
		background: var(--copper-dark);
		border-color: var(--copper-dark);
		transform: translateY(-1px);
	}
	.btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}
	.btn-full {
		width: 100%;
		text-align: center;
	}
	.btn-outline {
		display: inline-block;
		padding: 0.7em 1.8em;
		background: transparent;
		color: var(--copper);
		border: 1.5px solid var(--copper);
		border-radius: var(--radius-sm);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		font-weight: 600;
		text-decoration: none;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: all var(--duration) var(--ease);
		cursor: pointer;
	}
	.btn-outline:hover {
		background: var(--copper);
		color: #fff;
		transform: translateY(-1px);
	}

	/* ── Status messages ── */
	.status-msg {
		padding: var(--space-lg);
		border-radius: var(--radius-md);
		font-size: var(--text-sm);
	}
	.status-error {
		background: #fef2f2;
		border: 1px solid #fecaca;
		color: #b91c1c;
	}
	.status-success {
		background: var(--forest-mist);
		border: 1px solid var(--forest-light);
		color: var(--forest-dark);
		text-align: center;
		padding: var(--space-2xl);
	}
	.status-success h3 {
		font-size: var(--text-2xl);
		margin-bottom: var(--space-sm);
		color: var(--forest);
	}
	.status-success p {
		color: var(--text-muted);
		margin-bottom: var(--space-lg);
	}

	/* ── Utilities ── */
	.hidden { display: none !important; }
</style>
