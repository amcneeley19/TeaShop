---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SHOP_NAME, BOOKING_URL } from '../data/config';
import eventsData from '../data/events.json';

const packages = eventsData.teaParties.map((pkg: any, i: number) => ({
	...pkg,
	number: String(i + 1).padStart(2, '0'),
}));
const upgrades = eventsData.upgrades;

// Format event dates for display
const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const events = eventsData.events.map((e: any) => {
	const d = new Date(e.date + 'T12:00:00');
	const monthStr = months[d.getMonth()];
	const dayNum = d.getDate();
	const dayName = dayNames[d.getDay()];
	const dateText = `${dayName}, ${monthStr === 'Jan' ? 'January' : monthStr === 'Feb' ? 'February' : monthStr === 'Mar' ? 'March' : monthStr === 'Apr' ? 'April' : monthStr === 'May' ? 'May' : monthStr === 'Jun' ? 'June' : monthStr === 'Jul' ? 'July' : monthStr === 'Aug' ? 'August' : monthStr === 'Sep' ? 'September' : monthStr === 'Oct' ? 'October' : monthStr === 'Nov' ? 'November' : 'December'} ${dayNum}, ${d.getFullYear()}`;
	const spotsWarn = e.spots <= 5;
	const spotsText = spotsWarn ? `Only ${e.spots} spots left` : `${e.spots} spots available`;
	return { ...e, title: e.name, month: monthStr, day: dayNum, dateText, spotsWarn, spots: spotsText };
});
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Events & Tea Parties — ${SHOP_NAME}`} description={`Book a tea party or join one of our upcoming events. Tastings, workshops, and special occasions at ${SHOP_NAME}.`} />
	</head>
	<body>
		<Header />
		<section class="page-hero">
			<span class="label">Gatherings</span>
			<h1>Events & Tea Parties</h1>
			<p class="subtitle">Gather, sip, and celebrate</p>
		</section>
		<main>
			<!-- Tea Parties -->
			<section class="tp-section">
				<div class="tp-intro">
					<h2>Infinite Tea: Host With Us!</h2>
					<p>Gather your friends and family for an unforgettable afternoon in our cozy tea room. We'll handle everything — from the tea to the treats — so you can simply relax and enjoy.</p>
					<div class="tp-hours">
						<span class="label">Wednesday – Sunday, 11 AM – 1 PM</span>
						<span class="tp-note">Evening hours may be available upon request</span>
					</div>
				</div>

				<div class="packages-grid">
					{packages.map((pkg) => (
						<div class={`package-card ${pkg.featured ? 'featured' : ''}`}>
							{pkg.featured && <span class="ribbon">Most Popular</span>}
							<span class="pkg-number">{pkg.number}</span>
							<h3>{pkg.name}</h3>
							<div class="pkg-price">
								<span class="price">{pkg.price}</span>
								<span class="price-note">{pkg.priceNote}</span>
							</div>
							<div class="pkg-meta">
								<span>{pkg.guests}</span>
								<span class="dot">&middot;</span>
								<span>{pkg.duration}</span>
							</div>
							<ul class="pkg-includes">
								{pkg.includes.map((item) => <li>{item}</li>)}
							</ul>
							<a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="pkg-btn">Book Now</a>
						</div>
					))}
				</div>

				<div class="upgrades">
					<h3>Add-Ons & Upgrades</h3>
					<div class="upgrades-list">
						{upgrades.map((u) => (
							<div class="upgrade-item">
								<span>{u.name}</span>
								<span class="upgrade-price">{u.price}</span>
							</div>
						))}
					</div>
				</div>

				<!-- Booking placeholder -->
				<div class="booking-embed">
					<h3>Book Your Tea Party</h3>
					<p>Select a date and time that works for you.</p>
					<div class="embed-box">
						<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
						<p>Square Appointments widget will appear here</p>
					</div>
					<a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn">Book on Square</a>
				</div>
			</section>

			<div class="ornament" aria-hidden="true">&#10045;</div>

			<!-- Upcoming Events -->
			<section class="events-section">
				<div class="section-header">
					<span class="label">What's Coming Up</span>
					<h2>Upcoming Events</h2>
				</div>
				<div class="events-list">
					{events.map((event: any) => (
						<div class="event-card">
							<div class="event-date">
								<span class="month">{event.month}</span>
								<span class="day">{event.day}</span>
							</div>
							<div class="event-body">
								<span class="event-cat label">{event.category}</span>
								<h3>{event.title}</h3>
								<div class="event-meta">
									<span>{event.dateText}</span>
									<span class="dot">&middot;</span>
									<span>{event.time}</span>
								</div>
								<p>{event.description}</p>
								<div class="event-footer">
									<span class="event-price">{event.price}</span>
									<span class={event.spotsWarn ? 'spots-warn' : 'spots'}>{event.spots}</span>
									<a href="/contact" class="event-btn">Reserve</a>
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Private CTA -->
			<div class="private-cta">
				<h2>Planning Something Special?</h2>
				<p>We host private events, bridal showers, birthday parties, and corporate gatherings.</p>
				<a href="/contact" class="btn">Get in Touch</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-hero {
		background: var(--forest-mist);
		padding: var(--space-3xl) var(--space-lg) var(--space-xl);
		text-align: center;
	}
	.page-hero .label { margin-bottom: var(--space-xs); display: block; }
	.page-hero h1 { margin-bottom: var(--space-xs); }
	.subtitle {
		font-family: 'Cormorant Garamond', serif;
		color: var(--text-muted);
		font-style: italic;
		font-size: var(--text-lg);
		margin: 0;
	}
	main {
		max-width: 1100px;
		padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
	}

	/* ── Tea party intro ── */
	.tp-intro { max-width: 700px; margin: 0 auto var(--space-2xl); text-align: center; }
	.tp-intro h2 { margin-bottom: var(--space-sm); }
	.tp-intro p { color: var(--text-muted); line-height: 1.8; }
	.tp-hours { display: flex; flex-direction: column; align-items: center; gap: var(--space-xs); margin-top: var(--space-md); }
	.tp-hours .label { color: var(--forest); }
	.tp-note { font-size: var(--text-sm); color: var(--text-muted); font-style: italic; }

	/* ── Packages ── */
	.packages-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-lg);
		margin-bottom: var(--space-2xl);
	}
	.package-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		display: flex;
		flex-direction: column;
		position: relative;
		transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease), border-color var(--duration) var(--ease);
	}
	.package-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-lg);
		border-color: var(--copper-light);
	}
	.package-card.featured { border-color: var(--copper); border-width: 2px; }
	.ribbon {
		position: absolute;
		top: -1px;
		right: 20px;
		background: var(--copper);
		color: #fff;
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.35em 0.75em;
		border-radius: 0 0 var(--radius-sm) var(--radius-sm);
	}
	.pkg-number {
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-2xl);
		font-weight: 300;
		color: var(--dusty-rose);
		margin-bottom: var(--space-xs);
	}
	.package-card h3 { font-size: var(--text-xl); margin-bottom: var(--space-sm); }
	.pkg-price { display: flex; align-items: baseline; gap: var(--space-xs); margin-bottom: var(--space-xs); }
	.price {
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-4xl);
		font-weight: 500;
		color: var(--copper);
		line-height: 1;
	}
	.price-note { font-size: var(--text-sm); color: var(--text-muted); }
	.pkg-meta {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-bottom: var(--space-md);
	}
	.dot { opacity: 0.3; }
	.pkg-includes { list-style: none; padding: 0; margin: 0 0 var(--space-lg); flex: 1; }
	.pkg-includes li {
		font-size: var(--text-sm);
		color: var(--text-muted);
		padding: var(--space-xs) 0;
		border-bottom: 1px solid var(--border);
		line-height: 1.5;
	}
	.pkg-includes li:last-child { border-bottom: none; }
	.pkg-btn {
		display: block;
		text-align: center;
		padding: 0.7em 1.5em;
		background: var(--copper);
		color: #fff;
		border-radius: var(--radius-sm);
		font-weight: 600;
		font-size: var(--text-sm);
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		transition: all var(--duration) var(--ease);
	}
	.pkg-btn:hover {
		background: var(--copper-dark);
		transform: translateY(-1px);
		color: #fff;
	}

	/* ── Upgrades ── */
	.upgrades {
		background: var(--forest-mist);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg) var(--space-xl);
		margin-bottom: var(--space-2xl);
		text-align: center;
	}
	.upgrades h3 { font-size: var(--text-lg); margin-bottom: var(--space-md); }
	.upgrades-list { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-md); }
	.upgrade-item {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		background: #fff;
		padding: var(--space-sm) var(--space-md);
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		border: 1px solid var(--border);
	}
	.upgrade-price { color: var(--copper); font-weight: 600; }

	/* ── Booking embed ── */
	.booking-embed { text-align: center; max-width: 600px; margin: 0 auto var(--space-2xl); }
	.booking-embed h3 { font-size: var(--text-2xl); margin-bottom: var(--space-xs); }
	.booking-embed > p { color: var(--text-muted); margin-bottom: var(--space-lg); }
	.embed-box {
		background: var(--parchment-dark);
		border: 2px dashed var(--border-strong);
		border-radius: var(--radius-lg);
		padding: var(--space-3xl) var(--space-xl);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
		color: var(--text-muted);
		margin-bottom: var(--space-lg);
		opacity: 0.6;
	}
	.embed-box p { margin: 0; font-size: var(--text-sm); }
	.btn {
		display: inline-block;
		padding: 0.8em 2em;
		background: var(--copper);
		color: #fff;
		border: 2px solid var(--copper);
		border-radius: var(--radius-sm);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		font-weight: 600;
		text-decoration: none;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: all var(--duration) var(--ease);
	}
	.btn:hover {
		background: var(--copper-dark);
		border-color: var(--copper-dark);
		color: #fff;
		transform: translateY(-1px);
	}

	/* ── Events ── */
	.events-section { margin-bottom: var(--space-2xl); }
	.section-header { margin-bottom: var(--space-xl); }
	.section-header .label { display: block; margin-bottom: var(--space-xs); }
	.events-list { display: flex; flex-direction: column; gap: var(--space-lg); }
	.event-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		display: flex;
		overflow: hidden;
		transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease), border-color var(--duration) var(--ease);
	}
	.event-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
		border-color: var(--copper-light);
	}
	.event-date {
		background: var(--forest);
		color: #fff;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--space-lg) var(--space-xl);
		min-width: 85px;
		flex-shrink: 0;
	}
	.event-date .month {
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-weight: 600;
		opacity: 0.7;
	}
	.event-date .day {
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-4xl);
		font-weight: 400;
		line-height: 1;
	}
	.event-body { padding: var(--space-lg); flex: 1; }
	.event-cat { color: var(--forest); }
	.event-body h3 { font-size: var(--text-xl); margin: var(--space-xs) 0 var(--space-xs); }
	.event-meta {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-bottom: var(--space-sm);
	}
	.event-body p {
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin: 0 0 var(--space-md);
		line-height: 1.6;
	}
	.event-footer { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
	.event-price {
		font-family: 'Cormorant Garamond', serif;
		font-weight: 600;
		font-size: var(--text-xl);
		color: var(--copper);
	}
	.spots { font-size: var(--text-sm); color: var(--forest); }
	.spots-warn { font-size: var(--text-sm); color: #b84a2a; font-weight: 600; }
	.event-btn {
		padding: 0.4em 1em;
		border: 1.5px solid var(--copper);
		border-radius: var(--radius-sm);
		background: transparent;
		color: var(--copper);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 600;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		transition: all var(--duration) var(--ease);
		margin-left: auto;
	}
	.event-btn:hover { background: var(--copper); color: #fff; }

	/* ── Private CTA ── */
	.private-cta {
		background: var(--forest-mist);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-2xl);
		text-align: center;
	}
	.private-cta h2 { font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
	.private-cta p {
		color: var(--text-muted);
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-size: var(--text-lg);
		max-width: 550px;
		margin: 0 auto var(--space-lg);
	}

	@media (max-width: 600px) {
		.event-card { flex-direction: column; }
		.event-date {
			flex-direction: row;
			gap: var(--space-sm);
			padding: var(--space-sm) var(--space-md);
			min-width: auto;
		}
		.event-date .day { font-size: var(--text-2xl); }
	}
</style>
