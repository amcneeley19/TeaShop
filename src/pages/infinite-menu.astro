---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SHOP_NAME } from '../data/config';
import drinks from '../data/drinks.json';

const baseColors: Record<string, { bg: string; accent: string; text: string }> = {
	'Black Tea':  { bg: 'rgba(26, 18, 11, 0.07)',   accent: '#6b4226', text: '#3d2e22' },
	'Specialty':  { bg: 'rgba(140, 80, 60, 0.08)',   accent: '#8c503c', text: '#5a3020' },
	'Hibiscus':   { bg: 'rgba(196, 80, 100, 0.07)',  accent: '#c45064', text: '#8a3045' },
	'Herbal':     { bg: 'rgba(120, 140, 100, 0.08)', accent: '#6b8050', text: '#4a5a38' },
	'Chai':       { bg: 'rgba(180, 120, 60, 0.08)',  accent: '#b47830', text: '#6b4a20' },
	'Oolong Tea': { bg: 'rgba(184, 98, 63, 0.07)',   accent: '#b8623f', text: '#7a4a2e' },
	'Fruit':      { bg: 'rgba(200, 100, 120, 0.07)', accent: '#c86478', text: '#8a3050' },
	'Green Tea':  { bg: 'rgba(61, 90, 62, 0.08)',    accent: '#3d5a3e', text: '#2a3f2b' },
};

const bases = [...new Set(drinks.map(d => d.base))];

export const prerender = true;
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Infinite Tea Menu — ${SHOP_NAME}`} description="Our handcrafted boba and specialty tea drinks. Made fresh to order with fresh brewed tea, real fruit, and premium ingredients." />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="menu-hero">
			<div class="hero-wash"></div>
			<div class="hero-inner">
				<div class="teapot-icon" aria-hidden="true">
					<svg viewBox="0 0 64 64" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M20 22c0-4 4-8 12-8s12 4 12 8"></path>
						<ellipse cx="32" cy="22" rx="14" ry="4"></ellipse>
						<path d="M18 22v18c0 6 6 10 14 10s14-4 14-10V22"></path>
						<path d="M46 28h6a6 6 0 0 1 0 12h-6"></path>
						<path d="M28 14c-1-4 0-6 2-8"></path>
						<path d="M32 14c-1-4 0-7 3-9"></path>
						<path d="M36 14c-1-3 0-6 2-8"></path>
					</svg>
				</div>
				<h1 class="menu-title">Infinite Tea Menu</h1>
				<div class="ornament-line" aria-hidden="true">
					<span></span>
					<svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"></path></svg>
					<span></span>
				</div>
				<p class="menu-intro">
					All tea is made fresh to order with choice of fresh brewed tea, lemonade, sweeteners, fresh cooked tapioca boba or bursting boba, real freeze-dried fruit pieces and fruit powders, Ghirardelli syrup, dairy, or nondairy creamer and optional whipped cream topper.
				</p>
			</div>
		</section>

		<main>
			<!-- Filter bar -->
			<div class="filter-bar" role="group" aria-label="Filter by tea base">
				<button class="base-pill active" data-base="all" aria-pressed="true">All Drinks</button>
				{bases.map((base) => (
					<button class="base-pill" data-base={base} aria-pressed="false">
						<span class="pill-dot" style={`background: ${baseColors[base].accent}`}></span>
						{base}
					</button>
				))}
			</div>

			<div class="drink-count" id="drink-count" aria-live="polite">{drinks.length} drinks</div>

			<!-- Menu grid -->
			<div class="menu-grid" id="menu-grid">
				{drinks.map((drink, i) => {
					const c = baseColors[drink.base];
					return (
						<article
							class="drink-card"
							data-base={drink.base}
							data-name={drink.name}
							data-price12={drink.price12}
							data-price16={drink.price16}
							style={`--card-bg: ${c.bg}; --card-accent: ${c.accent}; --card-text: ${c.text}; --i: ${i}`}
						>
							<div class="card-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
							<div class="card-body">
								<h2 class="drink-name">{drink.name}</h2>
								<p class="drink-desc">{drink.desc}</p>

								<!-- Size toggle -->
								<div class="size-toggle" role="group" aria-label="Select size">
									<button class="size-btn active" data-size="12oz" aria-pressed="true">
										12 oz&nbsp;<span class="size-price">${drink.price12.toFixed(2)}</span>
									</button>
									<button class="size-btn" data-size="16oz" aria-pressed="false">
										16 oz&nbsp;<span class="size-price">${drink.price16.toFixed(2)}</span>
									</button>
								</div>

								<!-- Customization -->
								<div class="custom-row">
									<label class="custom-label">
										<span>Boba</span>
										<select class="custom-select boba-select">
											<option value="tapioca">Tapioca Boba</option>
											<option value="bursting">Bursting Boba</option>
											<option value="none">No Boba</option>
										</select>
									</label>
									<label class="custom-label">
										<span>Milk</span>
										<select class="custom-select milk-select">
											<option value="dairy">Dairy</option>
											<option value="nondairy">Nondairy</option>
										</select>
									</label>
									<label class="custom-label">
										<span>Sweet</span>
										<select class="custom-select sweet-select">
											<option value="full">Full</option>
											<option value="half">Half</option>
											<option value="light">Light</option>
											<option value="none">None</option>
										</select>
									</label>
									<div class="custom-label whip-group">
										<span>Whip</span>
										<div class="whip-toggle" role="group" aria-label="Whipped cream">
											<button class="whip-btn" data-whip="yes" aria-pressed="false">Yes</button>
											<button class="whip-btn active" data-whip="no" aria-pressed="true">No</button>
										</div>
									</div>
								</div>

								<!-- Add to Cart -->
								<button class="add-to-cart-btn" type="button">Add to Cart</button>
							</div>
							<span class="base-tag" style={`background: ${c.bg}; color: ${c.text}; border-color: ${c.accent}`}>
								{drink.base}
							</span>
						</article>
					);
				})}
			</div>

			<div class="empty-state" id="empty-state" style="display:none;">
				<p>No drinks match this filter.</p>
			</div>

			<!-- Bottom ornament -->
			<div class="bottom-section">
				<div class="ornament-line" aria-hidden="true">
					<span></span>
					<svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"></path></svg>
					<span></span>
				</div>
				<p class="bottom-note">
					Ask about our daily specials and seasonal creations.<br />
					All drinks can be made with dairy or nondairy options.
				</p>
				<a href="/tea-list" class="browse-link">Browse Our Loose Leaf Collection &rarr;</a>
			</div>
		</main>

		<Footer />

		<script>
			import { cart } from '../lib/cart-browser';
			import { slugify } from '../lib/utils';

			const grid = document.getElementById('menu-grid')!;
			const cards = Array.from(grid.querySelectorAll('.drink-card')) as HTMLElement[];
			const pills = document.querySelectorAll('.base-pill');
			const countEl = document.getElementById('drink-count')!;
			const emptyEl = document.getElementById('empty-state')!;
			let current = 'all';

			function filterDrinks() {
				let visible = 0;
				cards.forEach((card, i) => {
					const base = card.dataset.base || '';
					if (current === 'all' || base === current) {
						card.style.display = '';
						card.style.setProperty('--i', String(i));
						card.style.animation = 'cardReveal 0.4s var(--ease-out) forwards';
						card.style.animationDelay = `${visible * 30}ms`;
						visible++;
					} else {
						card.style.display = 'none';
						card.style.animation = '';
					}
				});
				countEl.textContent = `${visible} drink${visible !== 1 ? 's' : ''}`;
				emptyEl.style.display = visible === 0 ? '' : 'none';
			}

			pills.forEach((pill) => {
				pill.addEventListener('click', () => {
					pills.forEach((p) => {
						p.classList.remove('active');
						p.setAttribute('aria-pressed', 'false');
					});
					pill.classList.add('active');
					pill.setAttribute('aria-pressed', 'true');
					current = (pill as HTMLElement).dataset.base || 'all';
					filterDrinks();
				});
			});

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							(entry.target as HTMLElement).classList.add('visible');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
			);
			cards.forEach((card) => observer.observe(card));

			// ── Per-card interactivity ──────────────────────────────────────────

			cards.forEach((card) => {
				const price12 = parseFloat(card.dataset.price12 || '0');
				const price16 = parseFloat(card.dataset.price16 || '0');
				const name = card.dataset.name || '';

				const sizeBtns = card.querySelectorAll<HTMLButtonElement>('.size-btn');
				const bobaSelect = card.querySelector<HTMLSelectElement>('.boba-select')!;
				const milkSelect = card.querySelector<HTMLSelectElement>('.milk-select')!;
				const sweetSelect = card.querySelector<HTMLSelectElement>('.sweet-select')!;
				const whipBtns = card.querySelectorAll<HTMLButtonElement>('.whip-btn');
				const addBtn = card.querySelector<HTMLButtonElement>('.add-to-cart-btn')!;

				let selectedSize: '12oz' | '16oz' = '12oz';
				let selectedPrice = price12;
				let selectedWhip = false;

				// Size toggle
				sizeBtns.forEach((btn) => {
					btn.addEventListener('click', () => {
						sizeBtns.forEach((b) => {
							b.classList.remove('active');
							b.setAttribute('aria-pressed', 'false');
						});
						btn.classList.add('active');
						btn.setAttribute('aria-pressed', 'true');
						selectedSize = btn.dataset.size as '12oz' | '16oz';
						selectedPrice = selectedSize === '16oz' ? price16 : price12;
					});
				});

				// Whip toggle
				whipBtns.forEach((btn) => {
					btn.addEventListener('click', () => {
						whipBtns.forEach((b) => {
							b.classList.remove('active');
							b.setAttribute('aria-pressed', 'false');
						});
						btn.classList.add('active');
						btn.setAttribute('aria-pressed', 'true');
						selectedWhip = btn.dataset.whip === 'yes';
					});
				});

				// Add to cart
				addBtn.addEventListener('click', () => {
					const boba = bobaSelect.value as 'tapioca' | 'bursting' | 'none';
					const milk = milkSelect.value as 'dairy' | 'nondairy';
					const sweetness = sweetSelect.value as 'full' | 'half' | 'light' | 'none';
					const whip = selectedWhip;

					cart.addItem({
						type: 'drink',
						id: slugify('drink', name, selectedSize, boba, milk, sweetness, String(whip)),
						name,
						qty: 1,
						size: selectedSize,
						price: selectedPrice,
						options: { boba, milk, sweetness, whip },
					});

					// "Added!" feedback
					const original = addBtn.textContent;
					addBtn.textContent = 'Added!';
					addBtn.classList.add('added');
					addBtn.disabled = true;
					setTimeout(() => {
						addBtn.textContent = original;
						addBtn.classList.remove('added');
						addBtn.disabled = false;
					}, 1200);
				});
			});
		</script>
	</body>
</html>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap');

	/* ── Hero ── */
	.menu-hero {
		position: relative;
		padding: var(--space-4xl) var(--space-lg) var(--space-2xl);
		text-align: center;
		overflow: hidden;
		background: linear-gradient(170deg, var(--parchment) 0%, var(--parchment-dark) 40%, var(--copper-light) 100%);
	}
	.hero-wash {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 80% 60% at 20% 80%, rgba(61, 90, 62, 0.06) 0%, transparent 70%),
			radial-gradient(ellipse 60% 50% at 80% 20%, rgba(184, 98, 63, 0.06) 0%, transparent 70%);
		pointer-events: none;
	}
	.hero-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
	.teapot-icon {
		color: var(--copper);
		margin-bottom: var(--space-md);
		opacity: 0;
		animation: floatIn 0.8s var(--ease-out) 0.1s forwards;
	}
	.menu-title {
		font-family: 'Playfair Display', 'Cormorant Garamond', serif;
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 500;
		letter-spacing: -0.02em;
		color: var(--espresso);
		margin-bottom: var(--space-md);
		opacity: 0;
		animation: fadeUp 0.7s var(--ease-out) 0.25s forwards;
	}
	.ornament-line {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
		color: var(--dusty-rose);
	}
	.ornament-line span {
		display: block;
		width: 60px;
		height: 1px;
		background: linear-gradient(to right, transparent, var(--dusty-rose), transparent);
	}
	.menu-intro {
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-lg);
		font-style: italic;
		color: var(--espresso-mid);
		line-height: 1.7;
		margin: 0;
		opacity: 0;
		animation: fadeUp 0.7s var(--ease-out) 0.45s forwards;
	}

	/* ── Main ── */
	main {
		max-width: 960px;
		padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
	}

	/* ── Filter bar ── */
	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		justify-content: center;
		margin-bottom: var(--space-md);
	}
	.base-pill {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 0.4em 1em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: #fff;
		color: var(--text-muted);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 500;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
		white-space: nowrap;
	}
	.base-pill:hover {
		border-color: var(--copper);
		color: var(--copper-dark);
		transform: translateY(-1px);
	}
	.base-pill.active {
		background: var(--espresso);
		border-color: var(--espresso);
		color: var(--parchment);
		font-weight: 600;
	}
	.base-pill.active .pill-dot { background: var(--parchment) !important; }
	.pill-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
	.drink-count {
		text-align: center;
		font-size: var(--text-xs);
		color: var(--text-muted);
		opacity: 0.5;
		margin-bottom: var(--space-xl);
		font-weight: 500;
	}

	/* ── Menu grid ── */
	.menu-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: var(--space-md);
	}

	@keyframes cardReveal {
		0% { opacity: 0; transform: translateY(12px); }
		100% { opacity: 1; transform: translateY(0); }
	}

	.drink-card {
		position: relative;
		display: flex;
		align-items: flex-start;
		gap: var(--space-md);
		padding: var(--space-lg) var(--space-lg) var(--space-lg) calc(var(--space-lg) + 4px);
		background: #fff;
		border-radius: var(--radius-lg);
		border: 1px solid var(--border);
		border-left: 4px solid var(--card-accent, var(--copper));
		transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease), border-color var(--duration) var(--ease);
		opacity: 0;
		transform: translateY(12px);
	}
	.drink-card.visible {
		opacity: 1;
		transform: translateY(0);
		transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
		transition-delay: calc(var(--i, 0) * 40ms);
	}
	.drink-card:hover {
		transform: translateY(-3px) scale(1.005);
		box-shadow: var(--shadow-hover);
		border-left-width: 4px;
	}
	.drink-card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: var(--card-bg, transparent);
		opacity: 0;
		transition: opacity var(--duration) var(--ease);
		pointer-events: none;
	}
	.drink-card:hover::before { opacity: 1; }
	.card-number {
		font-family: 'Playfair Display', 'Cormorant Garamond', serif;
		font-size: var(--text-3xl);
		font-weight: 400;
		color: var(--card-accent, var(--copper));
		opacity: 0.18;
		line-height: 1;
		flex-shrink: 0;
		min-width: 36px;
		padding-top: 2px;
		transition: opacity var(--duration) var(--ease);
	}
	.drink-card:hover .card-number { opacity: 0.35; }
	.card-body { flex: 1; min-width: 0; position: relative; z-index: 1; }
	.drink-name {
		font-family: 'Playfair Display', 'Cormorant Garamond', serif;
		font-size: var(--text-xl);
		font-weight: 500;
		color: var(--espresso);
		margin: 0 0 var(--space-xs);
		line-height: 1.25;
	}
	.drink-desc {
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin: 0 0 var(--space-sm);
		line-height: 1.55;
	}
	.base-tag {
		position: relative;
		z-index: 1;
		font-size: 0.65rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.2em 0.55em;
		border-radius: var(--radius-full);
		border: 1px solid;
		white-space: nowrap;
		flex-shrink: 0;
		margin-top: 4px;
	}

	/* ── Size toggle ── */
	.size-toggle {
		display: flex;
		gap: 6px;
		margin-bottom: var(--space-sm);
	}
	.size-btn {
		flex: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 3px;
		padding: 0.3em 0.6em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: #fff;
		color: var(--text-muted);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 500;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
		white-space: nowrap;
	}
	.size-btn:hover {
		border-color: var(--card-accent, var(--copper));
		color: var(--card-accent, var(--copper));
	}
	.size-btn.active {
		background: var(--card-accent, var(--copper));
		border-color: var(--card-accent, var(--copper));
		color: #fff;
		font-weight: 600;
	}
	.size-price {
		opacity: 0.85;
		font-weight: 600;
	}

	/* ── Customization row ── */
	.custom-row {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-bottom: var(--space-sm);
		align-items: flex-end;
	}
	.custom-label {
		display: flex;
		flex-direction: column;
		gap: 2px;
		flex: 1;
		min-width: 0;
	}
	.custom-label > span {
		font-family: 'Outfit', sans-serif;
		font-size: 0.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--card-text, var(--text-muted));
		opacity: 0.7;
	}
	.custom-select {
		width: 100%;
		padding: 0.28em 0.4em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-sm, 4px);
		background: #fff;
		color: var(--text-muted);
		font-family: 'Outfit', sans-serif;
		font-size: 0.68rem;
		font-weight: 500;
		cursor: pointer;
		appearance: auto;
		transition: border-color var(--duration) var(--ease);
	}
	.custom-select:focus {
		outline: none;
		border-color: var(--card-accent, var(--copper));
	}

	/* ── Whip toggle ── */
	.whip-group {
		flex: 0 0 auto;
	}
	.whip-toggle {
		display: flex;
		gap: 4px;
	}
	.whip-btn {
		padding: 0.28em 0.55em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: #fff;
		color: var(--text-muted);
		font-family: 'Outfit', sans-serif;
		font-size: 0.68rem;
		font-weight: 500;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
		white-space: nowrap;
	}
	.whip-btn:hover {
		border-color: var(--card-accent, var(--copper));
		color: var(--card-accent, var(--copper));
	}
	.whip-btn.active {
		background: var(--card-accent, var(--copper));
		border-color: var(--card-accent, var(--copper));
		color: #fff;
