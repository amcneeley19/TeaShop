---
import { SHOP_NAME, SHOP_TAGLINE, SHOP_ADDRESS, SHOP_PHONE, SHOP_EMAIL, SHOP_HOURS, SOCIAL } from '../data/config';
---

<footer>
	<div class="footer-top">
		<div class="footer-brand">
			<div class="brand-mark">AE</div>
			<h3>{SHOP_NAME}</h3>
			<p class="brand-tagline">A tea house & art shop in the heart of Waynesville, Ohio.</p>
			<div class="social-links">
				<a href={SOCIAL.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
						<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
					</svg>
				</a>
				<a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
						<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
					</svg>
				</a>
			</div>
		</div>

		<div class="footer-col">
			<h4>Visit</h4>
			<address>
				<p>{SHOP_ADDRESS}</p>
				<p><a href={`tel:${SHOP_PHONE.replace(/[^0-9]/g, '')}`}>{SHOP_PHONE}</a></p>
				<p><a href={`mailto:${SHOP_EMAIL}`}>{SHOP_EMAIL}</a></p>
			</address>
		</div>

		<div class="footer-col">
			<h4>Hours</h4>
			<ul class="hours-list">
				{SHOP_HOURS.map((h) => (
					<li>
						<span class="day">{h.days}</span>
						<span class="time">{h.hours}</span>
					</li>
				))}
			</ul>
		</div>

		<div class="footer-col">
			<h4>Explore</h4>
			<ul class="footer-nav">
				<li><a href="/">Home</a></li>
				<li><a href="/tea-list">Tea List</a></li>
				<li><a href="/shop">Shop</a></li>
				<li><a href="/events">Events</a></li>
				<li><a href="/about">About</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</div>
	</div>

	<div class="footer-bottom">
		<p>&copy; {new Date().getFullYear()} {SHOP_NAME}. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		background: var(--espresso);
		color: var(--parchment);
		margin-top: 0;
	}

	.footer-top {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr 0.8fr;
		gap: var(--space-2xl);
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-4xl) var(--space-lg) var(--space-2xl);
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: 1.5px solid rgba(250, 246, 240, 0.25);
		color: var(--parchment);
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-sm);
		font-weight: 600;
		letter-spacing: 0.08em;
		border-radius: var(--radius-sm);
		margin-bottom: var(--space-md);
	}

	.footer-brand h3 {
		font-family: 'Cormorant Garamond', serif;
		color: var(--parchment);
		font-size: var(--text-xl);
		font-weight: 500;
		margin-bottom: var(--space-xs);
	}

	.brand-tagline {
		color: rgba(250, 246, 240, 0.5);
		font-size: var(--text-sm);
		font-style: italic;
		font-family: 'Cormorant Garamond', serif;
		margin-bottom: var(--space-lg);
		line-height: 1.5;
	}

	.social-links {
		display: flex;
		gap: var(--space-sm);
	}

	.social-links a {
		color: rgba(250, 246, 240, 0.4);
		transition: color var(--duration) var(--ease), transform var(--duration) var(--ease);
		display: flex;
		padding: 4px;
	}

	.social-links a:hover {
		color: var(--parchment);
		transform: translateY(-1px);
	}

	.footer-col h4 {
		font-family: 'Outfit', sans-serif;
		color: rgba(250, 246, 240, 0.4);
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		margin-bottom: var(--space-md);
	}

	address {
		font-style: normal;
	}

	address p {
		color: rgba(250, 246, 240, 0.6);
		font-size: var(--text-sm);
		margin-bottom: 0.3em;
	}

	address a {
		color: rgba(250, 246, 240, 0.6);
		text-decoration: none;
		transition: color var(--duration) var(--ease);
	}

	address a:hover {
		color: var(--parchment);
	}

	.hours-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.hours-list li {
		display: flex;
		flex-direction: column;
		margin-bottom: var(--space-sm);
		font-size: var(--text-sm);
	}

	.day {
		color: rgba(250, 246, 240, 0.4);
		font-size: var(--text-xs);
	}

	.time {
		color: var(--parchment);
	}

	.footer-nav {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-nav li {
		margin-bottom: 0.3em;
	}

	.footer-nav a {
		color: rgba(250, 246, 240, 0.6);
		text-decoration: none;
		font-size: var(--text-sm);
		transition: color var(--duration) var(--ease);
	}

	.footer-nav a:hover {
		color: var(--parchment);
	}

	.footer-bottom {
		border-top: 1px solid rgba(250, 246, 240, 0.08);
		text-align: center;
		padding: var(--space-lg);
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-bottom p {
		color: rgba(250, 246, 240, 0.25);
		font-size: var(--text-xs);
		margin: 0;
		letter-spacing: 0.02em;
	}

	@media (max-width: 768px) {
		.footer-top {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-xl);
		}
	}

	@media (max-width: 480px) {
		.footer-top {
			grid-template-columns: 1fr;
		}
	}
</style>
