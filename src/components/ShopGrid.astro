---
import products from '../data/products.json';

const categories = [...new Set(products.map((p: any) => p.category))];
---

<div class="shop-browser" id="shop-browser">
	<div class="search-wrap">
		<svg class="search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path>
		</svg>
		<label for="shop-search" class="sr-only">Search products</label>
		<input type="text" id="shop-search" placeholder="Search products..." autocomplete="off" aria-label="Search products by name or description" />
		<span class="item-count" id="item-count">{products.length} items</span>
	</div>

	<div class="filter-row" role="group" aria-label="Filter by product category">
		<button class="pill active" data-category="all" aria-pressed="true">All</button>
		{categories.map((cat: string) => (
			<button class="pill" data-category={cat} aria-pressed="false">{cat}</button>
		))}
	</div>

	<div class="product-grid" id="product-grid">
		{products.map((product: any) => (
			<div class="product-card" data-name={product.name.toLowerCase()} data-desc={product.description.toLowerCase()} data-category={product.category}>
				<div class="product-image">
					<div class="image-placeholder">
						<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
							<rect x="3" y="3" width="18" height="18" rx="2"></rect>
							<circle cx="8.5" cy="8.5" r="1.5"></circle>
							<path d="M21 15l-5-5L5 21"></path>
						</svg>
					</div>
				</div>
				<div class="product-body">
					<span class="product-cat label">{product.category}</span>
					<h3>{product.name}</h3>
					<p class="product-desc">{product.description}</p>
					<div class="product-footer">
						<span class="product-price">{product.price}</span>
						<button class="add-to-cart-btn" data-item-id={product.squareItemId} data-item-name={product.name} data-item-price={product.price} aria-label={`Add ${product.name} to cart`}>
							Add to Cart
						</button>
					</div>
				</div>
			</div>
		))}
	</div>

	<div class="empty-state" id="shop-empty" style="display:none;">
		<p>No products match your search.</p>
	</div>
</div>

<script>
	const searchInput = document.getElementById('shop-search') as HTMLInputElement;
	const grid = document.getElementById('product-grid')!;
	const cards = Array.from(grid.querySelectorAll('.product-card')) as HTMLElement[];
	const countEl = document.getElementById('item-count')!;
	const emptyEl = document.getElementById('shop-empty')!;
	const pills = document.querySelectorAll('.shop-browser .pill');
	let currentCategory = 'all';

	function filterProducts() {
		const query = searchInput.value.toLowerCase().trim();
		let count = 0;
		cards.forEach((card) => {
			const name = card.dataset.name || '';
			const desc = card.dataset.desc || '';
			const cat = card.dataset.category || '';
			if ((!query || name.includes(query) || desc.includes(query)) && (currentCategory === 'all' || cat === currentCategory)) {
				card.style.display = '';
				card.style.animation = 'fadeUp 0.3s var(--ease-out) forwards';
				count++;
			} else {
				card.style.display = 'none';
				card.style.animation = '';
			}
		});
		countEl.textContent = `${count} item${count !== 1 ? 's' : ''}`;
		emptyEl.style.display = count === 0 ? '' : 'none';
	}

	searchInput.addEventListener('input', filterProducts);

	pills.forEach((pill) => {
		pill.addEventListener('click', () => {
			pills.forEach((p) => { p.classList.remove('active'); p.setAttribute('aria-pressed', 'false'); });
			pill.classList.add('active');
			pill.setAttribute('aria-pressed', 'true');
			currentCategory = (pill as HTMLElement).dataset.category || 'all';
			filterProducts();
		});
	});

	document.querySelectorAll('.add-to-cart-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const button = btn as HTMLButtonElement;
			button.dataset.itemName;
			const badge = document.getElementById('cart-badge');
			if (badge) {
				const count = parseInt(badge.textContent || '0');
				badge.textContent = String(count + 1);
				badge.classList.add('has-items');
			}
			button.textContent = 'Added!';
			setTimeout(() => { button.textContent = 'Add to Cart'; }, 1200);
		});
	});
</script>

<style>
	.shop-browser { max-width: 1200px; margin: 0 auto; }

	.search-wrap { position: relative; display: flex; align-items: center; margin-bottom: var(--space-lg); }
	.search-icon { position: absolute; left: 16px; color: var(--text-muted); pointer-events: none; opacity: 0.4; }
	#shop-search {
		width: 100%;
		padding: 0.75em 1em 0.75em 2.75em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: #fff;
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		color: var(--text);
		transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
	}
	#shop-search:focus {
		outline: none;
		border-color: var(--forest);
		box-shadow: 0 0 0 3px rgba(61, 90, 62, 0.1);
	}
	#shop-search::placeholder { color: var(--text-muted); opacity: 0.5; }
	.item-count { position: absolute; right: 16px; font-size: var(--text-xs); color: var(--text-muted); opacity: 0.5; font-weight: 500; }

	.filter-row { display: flex; flex-wrap: wrap; gap: var(--space-xs); margin-bottom: var(--space-xl); }
	.pill {
		padding: 0.35em 0.9em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: #fff;
		color: var(--text-muted);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 500;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
		white-space: nowrap;
	}
	.pill:hover { border-color: var(--forest); color: var(--forest-dark); }
	.pill.active { background: var(--forest); border-color: var(--forest); color: #fff; font-weight: 600; }

	.product-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: var(--space-lg);
	}
	.product-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease), border-color var(--duration) var(--ease);
	}
	.product-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-lg);
		border-color: var(--copper-light);
	}
	.product-image { aspect-ratio: 4 / 3; overflow: hidden; }
	.image-placeholder {
		width: 100%;
		height: 100%;
		background: var(--parchment-dark);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-muted);
		opacity: 0.3;
	}
	.product-body { padding: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-xs); flex: 1; }
	.product-cat { color: var(--forest); }
	.product-body h3 { font-size: var(--text-lg); font-weight: 500; margin: 0; }
	.product-desc { font-size: var(--text-sm); color: var(--text-muted); margin: 0; line-height: 1.6; flex: 1; }
	.product-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: var(--space-md);
		padding-top: var(--space-md);
		border-top: 1px solid var(--border);
	}
	.product-price {
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-xl);
		font-weight: 600;
		color: var(--copper);
	}
	.add-to-cart-btn {
		padding: 0.4em 0.9em;
		border: 1.5px solid var(--copper);
		border-radius: var(--radius-sm);
		background: transparent;
		color: var(--copper);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
	}
	.add-to-cart-btn:hover { background: var(--copper); color: #fff; }
	.add-to-cart-btn:active { transform: scale(0.96); }

	.empty-state {
		text-align: center;
		padding: var(--space-3xl) var(--space-md);
		color: var(--text-muted);
		font-style: italic;
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-lg);
	}

	@media (max-width: 600px) {
		.product-grid { grid-template-columns: 1fr; }
	}
</style>
