---
import menu from '../data/menu.json';

const categories = ['All', ...new Set(menu.map((t: any) => t.category))];
const caffeineFilters = ['All', 'high', 'medium', 'low', 'none'];
---

<div class="tea-browser" id="tea-browser">
	<div class="search-wrap">
		<svg class="search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path>
		</svg>
		<label for="tea-search" class="sr-only">Search teas</label>
		<input type="text" id="tea-search" placeholder="Search teas..." autocomplete="off" aria-label="Search teas by name, category, or flavour" />
		<span class="tea-count" id="tea-count">{menu.length} teas</span>
	</div>

	<div class="filter-row" role="group" aria-label="Filter by category">
		{categories.map((cat: string) => (
			<button class={`pill ${cat === 'All' ? 'active' : ''}`} data-category={cat} aria-pressed={cat === 'All' ? 'true' : 'false'}>{cat}</button>
		))}
	</div>

	<div class="caffeine-row" role="group" aria-label="Filter by caffeine level">
		<span class="caffeine-label label">Caffeine:</span>
		{caffeineFilters.map((level: string) => (
			<button class={`caff-pill ${level === 'All' ? 'active' : ''}`} data-caffeine={level} aria-pressed={level === 'All' ? 'true' : 'false'}>{level === 'All' ? 'All' : level.charAt(0).toUpperCase() + level.slice(1)}</button>
		))}
	</div>

	<div class="tea-grid" id="tea-grid">
		{menu.map((tea: any) => (
			<div class="tea-card" data-name={tea.name.toLowerCase()} data-desc={tea.description.toLowerCase()} data-category={tea.category} data-caffeine={tea.caffeine} data-tags={tea.tags.join(' ')} data-price-per-oz={tea.pricePerOz}>
				<div class="card-top">
					<span class={`caff-dot caff-${tea.caffeine}`} title={`${tea.caffeine} caffeine`}></span>
					{tea.featured && <span class="featured-badge">Featured</span>}
					<span class="price-per-oz">${tea.pricePerOz.toFixed(2)}/oz</span>
				</div>
				<h3>{tea.name}</h3>
				<p class="card-cat">{tea.category}</p>
				<p class="card-desc">{tea.description}</p>
				<div class="card-tags">
					{tea.tags.map((tag: string) => <span class="tag">{tag}</span>)}
				</div>
				<div class="card-actions">
					<div class="stepper" aria-label="Select ounces">
						<button class="stepper-btn stepper-dec" aria-label="Decrease ounces">−</button>
						<span class="stepper-val">1</span>
						<button class="stepper-btn stepper-inc" aria-label="Increase ounces">+</button>
						<span class="stepper-unit">oz</span>
					</div>
					<span class="line-total">${tea.pricePerOz.toFixed(2)}</span>
				</div>
				<button class="add-to-cart-btn" data-name={tea.name} data-category={tea.category} data-price-per-oz={tea.pricePerOz} aria-label={`Add ${tea.name} to cart`}>Add to Cart</button>
			</div>
		))}
	</div>

	<div class="empty-state" id="tea-empty" style="display:none;">
		<p>No teas match your search.</p>
	</div>
</div>

<script>
	import { cart } from '../lib/cart-browser';
	import { slugify } from '../lib/utils';

	const searchInput = document.getElementById('tea-search') as HTMLInputElement;
	const grid = document.getElementById('tea-grid')!;
	const cards = Array.from(grid.querySelectorAll('.tea-card')) as HTMLElement[];
	const countEl = document.getElementById('tea-count')!;
	const emptyEl = document.getElementById('tea-empty')!;
	const categoryPills = document.querySelectorAll('.tea-browser .pill');
	const caffeinePills = document.querySelectorAll('.tea-browser .caff-pill');

	let currentCategory = 'All';
	let currentCaffeine = 'All';

	function filterTeas() {
		const query = searchInput.value.toLowerCase().trim();
		let count = 0;
		cards.forEach((card) => {
			const name = card.dataset.name || '';
			const desc = card.dataset.desc || '';
			const tags = card.dataset.tags || '';
			const cat = card.dataset.category || '';
			const caff = card.dataset.caffeine || '';
			const matchSearch = !query || name.includes(query) || desc.includes(query) || tags.includes(query);
			const matchCat = currentCategory === 'All' || cat === currentCategory;
			const matchCaff = currentCaffeine === 'All' || caff === currentCaffeine;
			if (matchSearch && matchCat && matchCaff) {
				card.style.display = '';
				card.style.animation = 'fadeUp 0.3s var(--ease-out) forwards';
				count++;
			} else {
				card.style.display = 'none';
				card.style.animation = '';
			}
		});
		countEl.textContent = `${count} tea${count !== 1 ? 's' : ''}`;
		emptyEl.style.display = count === 0 ? '' : 'none';
	}

	searchInput.addEventListener('input', filterTeas);

	categoryPills.forEach((pill) => {
		pill.addEventListener('click', () => {
			categoryPills.forEach((p) => { p.classList.remove('active'); p.setAttribute('aria-pressed', 'false'); });
			pill.classList.add('active');
			pill.setAttribute('aria-pressed', 'true');
			currentCategory = (pill as HTMLElement).dataset.category || 'All';
			filterTeas();
		});
	});

	caffeinePills.forEach((pill) => {
		pill.addEventListener('click', () => {
			caffeinePills.forEach((p) => { p.classList.remove('active'); p.setAttribute('aria-pressed', 'false'); });
			pill.classList.add('active');
			pill.setAttribute('aria-pressed', 'true');
			currentCaffeine = (pill as HTMLElement).dataset.caffeine || 'All';
			filterTeas();
		});
	});

	// Stepper and add-to-cart logic
	cards.forEach((card) => {
		const decBtn = card.querySelector('.stepper-dec') as HTMLButtonElement;
		const incBtn = card.querySelector('.stepper-inc') as HTMLButtonElement;
		const valEl = card.querySelector('.stepper-val') as HTMLElement;
		const totalEl = card.querySelector('.line-total') as HTMLElement;
		const addBtn = card.querySelector('.add-to-cart-btn') as HTMLButtonElement;
		const pricePerOz = parseFloat(card.dataset.pricePerOz || '0');

		let ounces = 1;

		function updateDisplay() {
			valEl.textContent = String(ounces);
			totalEl.textContent = `$${(ounces * pricePerOz).toFixed(2)}`;
			decBtn.disabled = ounces <= 1;
			incBtn.disabled = ounces >= 16;
		}

		updateDisplay();

		decBtn.addEventListener('click', () => {
			if (ounces > 1) { ounces--; updateDisplay(); }
		});

		incBtn.addEventListener('click', () => {
			if (ounces < 16) { ounces++; updateDisplay(); }
		});

		addBtn.addEventListener('click', () => {
			const name = addBtn.dataset.name || '';
			const category = addBtn.dataset.category || '';
			cart.addItem({
				type: 'tea',
				id: slugify(name),
				name,
				category,
				ounces,
				pricePerOz,
			});

			const original = addBtn.textContent;
			addBtn.textContent = 'Added!';
			addBtn.classList.add('added');
			setTimeout(() => {
				addBtn.textContent = original;
				addBtn.classList.remove('added');
			}, 1200);
		});
	});
</script>

<style>
	.tea-browser { max-width: 1200px; margin: 0 auto; }

	.search-wrap { position: relative; display: flex; align-items: center; margin-bottom: var(--space-lg); }
	.search-icon { position: absolute; left: 16px; color: var(--text-muted); pointer-events: none; opacity: 0.4; }
	#tea-search {
		width: 100%;
		padding: 0.75em 1em 0.75em 2.75em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: #fff;
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		color: var(--text);
		transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
	}
	#tea-search:focus {
		outline: none;
		border-color: var(--forest);
		box-shadow: 0 0 0 3px rgba(61, 90, 62, 0.1);
	}
	#tea-search::placeholder { color: var(--text-muted); opacity: 0.5; }
	.tea-count { position: absolute; right: 16px; font-size: var(--text-xs); color: var(--text-muted); opacity: 0.5; font-weight: 500; }

	.filter-row { display: flex; flex-wrap: wrap; gap: var(--space-xs); margin-bottom: var(--space-sm); }
	.pill {
		padding: 0.35em 0.9em;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: #fff;
		color: var(--text-muted);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 500;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
		white-space: nowrap;
	}
	.pill:hover { border-color: var(--forest); color: var(--forest-dark); }
	.pill.active { background: var(--forest); border-color: var(--forest); color: #fff; font-weight: 600; }

	.caffeine-row { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-xs); margin-bottom: var(--space-xl); }
	.caffeine-label { margin-right: var(--space-xs); }
	.caff-pill {
		padding: 0.25em 0.7em;
		border: 1px solid var(--border-strong);
		border-radius: var(--radius-full);
		background: transparent;
		color: var(--text-muted);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-xs);
		font-weight: 500;
		cursor: pointer;
		transition: all var(--duration) var(--ease);
	}
	.caff-pill:hover { border-color: var(--copper); color: var(--copper); }
	.caff-pill.active { background: var(--copper-light); border-color: var(--copper); color: var(--copper-dark); font-weight: 600; }

	.tea-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: var(--space-lg);
	}
	.tea-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease), border-color var(--duration) var(--ease);
	}
	.tea-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-lg);
		border-color: var(--copper-light);
	}
	.card-top { display: flex; align-items: center; gap: var(--space-sm); }
	.caff-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
	.caff-high { background: var(--copper); }
	.caff-medium { background: #d4a574; }
	.caff-low { background: var(--forest); }
	.caff-none { background: #8ba4ad; }
	.featured-badge {
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.15em 0.5em;
		border-radius: var(--radius-full);
		background: var(--copper-light);
		color: var(--copper-dark);
	}
	.price-per-oz {
		margin-left: auto;
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--forest);
	}
	.tea-card h3 { font-size: var(--text-lg); font-weight: 500; margin: 0; }
	.card-cat {
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
		color: var(--forest);
		margin: 0;
	}
	.card-desc { font-size: var(--text-sm); color: var(--text-muted); margin: 0; line-height: 1.6; flex: 1; }
	.card-tags { display: flex; flex-wrap: wrap; gap: var(--space-xs); margin-top: var(--space-sm); }
	.tag {
		font-size: var(--text-xs);
		padding: 0.15em 0.5em;
		background: var(--parchment-dark);
		color: var(--text-muted);
		border-radius: var(--radius-full);
		font-weight: 500;
	}

	/* Card actions row: stepper + line total */
	.card-actions {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		margin-top: var(--space-sm);
	}
	.stepper {
		display: flex;
		align-items: center;
		gap: 0;
		border: 1.5px solid var(--border-strong);
		border-radius: var(--radius-full);
		overflow: hidden;
		background: #fff;
	}
	.stepper-btn {
		width: 28px;
		height: 28px;
		border: none;
		background: transparent;
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background var(--duration) var(--ease), color var(--duration) var(--ease);
		flex-shrink: 0;
	}
	.stepper-btn:hover:not(:disabled) { background: var(--parchment-dark); color: var(--forest); }
	.stepper-btn:disabled { opacity: 0.3; cursor: default; }
	.stepper-val {
		min-width: 22px;
		text-align: center;
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--text);
		font-family: 'Outfit', sans-serif;
		padding: 0 2px;
	}
	.stepper-unit {
		font-size: var(--text-xs);
		color: var(--text-muted);
		padding-right: 8px;
		font-family: 'Outfit', sans-serif;
	}
	.line-total {
		margin-left: auto;
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--text);
		font-family: 'Outfit', sans-serif;
		min-width: 3.5rem;
		text-align: right;
	}

	/* Add to Cart button */
	.add-to-cart-btn {
		margin-top: var(--space-xs);
		width: 100%;
		padding: 0.55em 1em;
		background: var(--forest);
		color: #fff;
		border: none;
		border-radius: var(--radius-full);
		font-family: 'Outfit', sans-serif;
		font-size: var(--text-sm);
		font-weight: 600;
		cursor: pointer;
		transition: background var(--duration) var(--ease), transform var(--duration) var(--ease);
	}
	.add-to-cart-btn:hover { background: var(--forest-dark, #2d4a2e); transform: translateY(-1px); }
	.add-to-cart-btn:active { transform: translateY(0); }
	.add-to-cart-btn.added { background: var(--copper, #b87333); }

	.empty-state {
		text-align: center;
		padding: var(--space-3xl) var(--space-md);
		color: var(--text-muted);
		font-style: italic;
		font-family: 'Cormorant Garamond', serif;
		font-size: var(--text-lg);
	}

	@media (max-width: 600px) {
		.tea-grid { grid-template-columns: 1fr; }
	}
</style>
